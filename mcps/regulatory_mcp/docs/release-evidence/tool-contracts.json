      "description": "Return MCP server health, metadata, and optional corpus stats.",
      "input_parameters": {
        "include_corpus": {
          "type": "boolean",
          "required": false,
          "description": "Include corpus statistics in response"
        }
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true
      }
    },
    {
      "name": "get_regulatory_profile",
      "title": "Regulatory Profile",
      "description": "Return regulations, controls, and corpus stats filtered by domain or jurisdiction.",
      "input_parameters": {
        "domains": {
          "type": "array",
          "items": "string",
          "required": false,
          "description": "Filter by regulatory domains"
        },
        "jurisdiction": {
          "type": "string",
          "required": false,
          "description": "Filter by jurisdiction (e.g., EU, GLOBAL, INTERNAL)"
