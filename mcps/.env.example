# Example values only. Copy this file to mcps/.env and keep real local secrets out of git.

SONARQUBE_PORT=9000
SONARQUBE_ADMIN_USER=admin
SONARQUBE_ADMIN_PASSWORD=<local-sonarqube-admin-password>
SONARQUBE_TOKEN_NAME=risktrace-local-mcp
SONARQUBE_TOOLSETS=projects,analysis,issues,quality-gates
SONARQUBE_BACKEND_PROJECT_KEY=risktrace-control-tower-backend
SONARQUBE_BACKEND_PROJECT_NAME="RiskTrace Control Tower Backend"
SONARQUBE_FRONTEND_PROJECT_KEY=risktrace-control-tower-frontend
SONARQUBE_FRONTEND_PROJECT_NAME="RiskTrace Control Tower Frontend"

SONAR_POSTGRES_DB=risktrace_sonarqube
SONAR_POSTGRES_USER=risktrace_sonar
SONAR_POSTGRES_PASSWORD=<local-sonarqube-db-password>

ZAP_PORT=8090
ZAP_API_KEY=<local-zap-api-key>
ZAP_MCP_PORT=8282
ZAP_MCP_URL=http://127.0.0.1:8282
ZAP_MCP_SECURITY_KEY=<local-zap-mcp-security-key>
ZAP_MCP_TARGET_URL=http://127.0.0.1:5173

SONATYPE_GUIDE_MCP_TOKEN=<sonatype-guide-token>
