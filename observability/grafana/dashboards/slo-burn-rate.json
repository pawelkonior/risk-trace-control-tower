{
  "uid": "rwa-slo-burn",
  "title": "RWA — SLO Burn Rate",
  "tags": ["rwa", "slo", "reliability"],
  "timezone": "utc",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "30-day Error Budget Remaining",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{job=\"rwa-calculator\",status=~\"5..\"}[30d])) / sum(rate(http_requests_total{job=\"rwa-calculator\"}[30d]))) / 0.01",
          "legendFormat": "budget remaining"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.25 },
              { "color": "green", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "1h Burn Rate (×)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"rwa-calculator\",status=~\"5..\"}[1h])) / sum(rate(http_requests_total{job=\"rwa-calculator\"}[1h])) / 0.01",
          "legendFormat": "1h burn"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "6h Burn Rate (×)",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"rwa-calculator\",status=~\"5..\"}[6h])) / sum(rate(http_requests_total{job=\"rwa-calculator\"}[6h])) / 0.01",
          "legendFormat": "6h burn"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "p95 Latency vs 2s SLO",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"rwa-calculator\"}[5m])) by (le))",
          "legendFormat": "p95 latency"
        },
        {
          "expr": "2",
          "legendFormat": "SLO (2s)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SLO (2s)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 5], "fill": "dash" } }
            ]
          }
        ]
      }
    }
  ]
}
