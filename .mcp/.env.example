# Example values only. Do not put real local tokens or passwords in this file.
#
# The setup scripts create gitignored files under .mcp/local/ for local secrets.
# Use these names when overriding values in your shell or local env files.

SONARQUBE_PORT=9000
SONARQUBE_URL=http://127.0.0.1:9000
SONARQUBE_ADMIN_USER=<local-sonarqube-admin-user>
SONARQUBE_ADMIN_PASSWORD=<local-sonarqube-admin-password>
SONARQUBE_TOKEN=<local-sonarqube-user-token>
SONARQUBE_BACKEND_PROJECT_KEY=risktrace-control-tower-backend
SONARQUBE_FRONTEND_PROJECT_KEY=risktrace-control-tower-frontend

SONAR_POSTGRES_DB=risktrace_sonarqube
SONAR_POSTGRES_USER=<local-sonarqube-db-user>
SONAR_POSTGRES_PASSWORD=<local-sonarqube-db-password>

ZAP_PORT=8090
ZAP_BASE_URL=http://127.0.0.1:8090
ZAP_API_KEY=<local-zap-api-key>
ZAP_MCP_PORT=8282
ZAP_MCP_URL=http://127.0.0.1:8282
ZAP_MCP_SECURITY_KEY=<local-zap-mcp-security-key>
ZAP_MCP_TARGET_URL=http://127.0.0.1:5173

SONATYPE_GUIDE_MCP_TOKEN=<sonatype-guide-token-exported-in-your-shell>
