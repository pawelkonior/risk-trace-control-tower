{
  "mcpServers": {
    "atlassian": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp",
        "--transport",
        "http-first"
      ],
      "command": "npx"
    },
    "owaspZap": {
      "args": [
        "compose",
        "--env-file",
        ".mcp/.env",
        "-f",
        ".mcp/docker-compose.yml",
        "--profile",
        "mcp",
        "run",
        "--rm",
        "-T",
        "owasp-zap-mcp"
      ],
      "command": "docker"
    },
    "risktrace-sonarqube": {
      "args": [
        "compose",
        "--env-file",
        ".mcp/.env",
        "-f",
        ".mcp/docker-compose.yml",
        "--profile",
        "mcp",
        "run",
        "--rm",
        "-T",
        "sonarqube-mcp"
      ],
      "command": "docker"
    },
    "sonatype-guide": {
      "args": [
        "compose",
        "--env-file",
        ".mcp/.env",
        "-f",
        ".mcp/docker-compose.yml",
        "--profile",
        "mcp",
        "run",
        "--rm",
        "-T",
        "sonatype-guide-mcp"
      ],
      "command": "docker"
    }
  }
}
