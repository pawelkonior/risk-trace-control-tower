{
  "_risktrace": {
    "generatedBy": ".mcp/scripts/generate-mcp-config.sh",
    "secretPolicy": "MCP config uses environment references and local launcher env files only."
  },
  "mcpServers": {
    "atlassian": {
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp",
        "--transport",
        "http-first"
      ],
      "command": "npx"
    },
    "owaspZap": {
      "command": ".mcp/scripts/run-zap-mcp.sh",
      "env": {
        "ZAP_MCP_ENV_FILE": "/home/cezary/projects/risk-trace-control-tower/.mcp/local/zap-mcp.env"
      }
    },
    "risktrace-sonarqube": {
      "command": ".mcp/scripts/run-sonarqube-mcp.sh",
      "env": {
        "SONARQUBE_MCP_ENV_FILE": "/home/cezary/projects/risk-trace-control-tower/.mcp/local/sonarqube-mcp.env",
        "SONARQUBE_TOKEN": "${env:SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "http://127.0.0.1:9000"
      }
    }
  }
}
